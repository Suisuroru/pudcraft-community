# ============================================
# Pudcraft Community — 环境变量配置
# 复制此文件为 .env 后填入真实值
# cp .env.example .env
# ============================================

# === 数据库（PostgreSQL） ===
DATABASE_URL="postgresql://pudcraft:pudcraft_dev@localhost:5432/pudcraft?schema=public"

# === Redis ===
REDIS_URL="redis://localhost:6379"

# === 应用配置 ===
NODE_ENV="development"
LOG_LEVEL="info"
NEXTAUTH_SECRET="replace_with_openssl_rand_base64_32"
# 生产自托管时必须设置；Vercel / 本地开发可不设（NextAuth v5 自动推断）
# NEXTAUTH_URL="https://your-domain.com"

# === SMTP（飞书企业邮箱） ===
SMTP_HOST="smtp.feishu.cn"
SMTP_PORT="465"
SMTP_USER="secure@pudcraft.cn"
SMTP_PASS="your_smtp_password_or_app_token"
SMTP_FROM="PudCraft <secure@pudcraft.cn>"

# === 文件存储 ===
# 存储驱动：local（本地开发）或 s3（S3 兼容对象存储）
STORAGE_DRIVER="local"

# === S3 兼容对象存储（Cloudflare R2 / MinIO / AWS S3 等） ===
# S3_REGION="auto"
# S3_BUCKET="your-bucket-name"
# S3_ACCESS_KEY_ID="your-access-key-id"
# S3_ACCESS_KEY_SECRET="your-access-key-secret"
# S3_ENDPOINT="https://your-object-storage-endpoint"
# S3_PUBLIC_BASE_URL="https://cdn.example.com"
# S3_FORCE_PATH_STYLE="false"

# === 内容审查（DeepSeek / OpenAI 兼容 / Anthropic） ===
# MODERATION_API_KEY 必填，其余项有默认值，按需覆盖
MODERATION_API_KEY="sk-xxxxxxxxxxxxxxxx"
# MODERATION_ENABLED="true"                              # true | false，默认 true
# MODERATION_BASE_URL="https://api.deepseek.com"         # API 根地址
# MODERATION_MODE="openai"                               # openai | anthropic，默认 openai
# MODERATION_MODEL="deepseek-chat"                       # 模型名

# 切换到 OpenAI：
# MODERATION_BASE_URL="https://api.openai.com"
# MODERATION_MODEL="gpt-4o-mini"

# 切换到 Anthropic：
# MODERATION_BASE_URL="https://api.anthropic.com"
# MODERATION_MODE="anthropic"
# MODERATION_MODEL="claude-haiku-4-5-20251001"

# === 未来扩展（当前无需配置） ===
# NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# AUTH_SECRET="生成一个安全的随机字符串"
# RATE_LIMIT_MAX="60"
