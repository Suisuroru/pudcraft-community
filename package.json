{
  "name": "pudcraft-community",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css}\"",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "sync:favorite-counts": "tsx scripts/sync-favorite-counts.ts",
    "sync:favorite-count": "tsx prisma/sync-favorite-count.ts",
    "migrate:uploads": "tsx scripts/migrate-uploads-to-oss.ts",
    "migrate:uploads:dry": "tsx scripts/migrate-uploads-to-oss.ts --dry-run",
    "storage:check": "tsx scripts/verify-storage-behavior.ts",
    "worker": "tsx src/worker/index.ts",
    "worker:dev": "tsx watch src/worker/index.ts",
    "build:worker": "node -e \"require('esbuild').buildSync({entryPoints:['src/worker/index.ts'],bundle:true,platform:'node',target:'node24',outfile:'dist/worker.js',tsconfig:'tsconfig.json',external:['@prisma/client']})\"",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@alicloud/green20220302": "3.0.1",
    "@alicloud/openapi-core": "^1.0.7",
    "@auth/prisma-adapter": "^2.11.1",
    "@aws-sdk/client-s3": "^3.1000.0",
    "@aws-sdk/s3-request-presigner": "^3.1000.0",
    "@darabonba/typescript": "^1.0.4",
    "@prisma/client": "^6.2.0",
    "@tiptap/extension-image": "^3.20.0",
    "@tiptap/extension-link": "^3.20.0",
    "@tiptap/extension-underline": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.30.0",
    "cropperjs": "^1.6.2",
    "graceful-fs": "^4.2.11",
    "ioredis": "^5.4.0",
    "markdown-it": "^14.1.1",
    "minecraft-server-util": "^5.4.4",
    "next": "^15.1.0",
    "next-auth": "5.0.0-beta.30",
    "nodemailer": "^7.0.7",
    "react": "^19.0.0",
    "react-cropper": "^2.3.3",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sanitize-html": "^2.17.1",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2",
    "yauzl": "^3.2.0",
    "zod": "^3.24.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "sharp",
      "msgpackr-extract",
      "unrs-resolver"
    ]
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/bcryptjs": "^3.0.0",
    "@types/cropperjs": "^1.3.3",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^7.0.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/sanitize-html": "^2.16.0",
    "@types/turndown": "^5.0.6",
    "@types/yauzl": "^2.10.3",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.5.0",
    "prettier": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "prisma": "^6.2.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
