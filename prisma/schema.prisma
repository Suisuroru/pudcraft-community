// ============================================
// Pudcraft Community — 数据库 Schema
// 使用 Prisma ORM + PostgreSQL
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// 用户表 —— 未来用于登录、认领服务器、发送消息等
model User {
  id            String    @id @default(cuid())
  uid           Int       @unique @map("uid")
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  passwordHash  String    @map("password_hash")
  image         String?
  bio           String?   @db.Text
  role          String    @default("user") // user | admin | moderator
  isBanned      Boolean   @default(false) @map("is_banned")
  banReason     String?   @map("ban_reason")
  bannedAt      DateTime? @map("banned_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts       Account[]
  sessions       Session[]
  servers        Server[]
  comments       Comment[]
  favorites      Favorite[]
  modpacks       Modpack[]
  notifications  Notification[]
  moderationLogs ModerationLog[]
  changelogs     Changelog[]
  applications   ServerApplication[] @relation("ApplicationUser")
  reviewedApps   ServerApplication[] @relation("ApplicationReviewer")
  serverInvites  ServerInvite[]
  serverMembers  ServerMember[]

  @@map("users")
}

/// 服务器表 —— 核心实体，每条记录对应一个 Minecraft 服务器
model Server {
  id              String    @id @default(cuid())
  psid            Int       @unique @map("psid")
  name            String
  host            String
  port            Int       @default(25565)
  description     String?
  tags            String[]  @default([])
  imageUrl        String?   @map("image_url")
  iconUrl         String?   @map("icon_url")
  ownerId         String?   @map("owner_id")
  owner           User?     @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  isVerified      Boolean   @default(false) @map("is_verified")
  verifyToken     String?   @map("verify_token")
  verifyExpiresAt DateTime? @map("verify_expires_at")
  verifyUserId    String?   @map("verify_user_id")
  verifiedAt      DateTime? @map("verified_at")
  favoriteCount   Int       @default(0) @map("favorite_count")
  isOnline        Boolean   @default(false) @map("is_online")
  playerCount     Int       @default(0) @map("player_count")
  maxPlayers      Int       @default(0) @map("max_players")
  lastPingedAt    DateTime? @map("last_pinged_at")
  status          String    @default("pending") // pending | approved | rejected
  rejectReason    String?   @map("reject_reason")
  visibility      String    @default("public") @map("visibility") // public | private | unlisted
  joinMode        String    @default("open") @map("join_mode") // open | apply | invite | apply_and_invite
  applicationForm Json?     @map("application_form")
  apiKeyHash      String?   @map("api_key_hash")

  content String? @db.Text // Markdown 详细介绍

  // 未来扩展字段（认领）：
  // claimToken  String?  @unique @map("claim_token")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  statuses     ServerStatus[]
  comments     Comment[]
  favorites    Favorite[]
  modpacks     Modpack[]
  applications ServerApplication[]
  invites      ServerInvite[]
  members      ServerMember[]
  syncs        WhitelistSync[]

  // 未来扩展：
  // channels Channel[]

  @@unique([host, port], name: "unique_host_port")
  @@index([status])
  @@index([ownerId])
  @@map("servers")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

/// 服务器状态记录 —— 由 Worker 定时 ping 后写入
model ServerStatus {
  id          String   @id @default(cuid())
  serverId    String   @map("server_id")
  online      Boolean  @default(false)
  playerCount Int?     @map("player_count")
  maxPlayers  Int?     @map("max_players")
  motd        String?
  favicon     String?  @db.Text
  version     String?
  error       String?  @db.Text
  checkedAt   DateTime @default(now()) @map("checked_at")

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, checkedAt(sort: Desc)])
  @@map("server_statuses")
}

/// 服务器评论 —— 支持两层结构（评论 + 回复）
model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  serverId String @map("server_id")
  server   Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  authorId String @map("author_id")
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  parentId String?   @map("parent_id")
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")

  @@index([serverId, createdAt(sort: Desc)])
  @@index([parentId])
  @@map("comments")
}

/// 服务器收藏关系 —— 用户与服务器多对多映射
model Favorite {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  serverId String @map("server_id")
  server   Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@unique([userId, serverId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([serverId])
  @@map("favorites")
}

/// 服务器整合包 —— 仅支持 Modrinth .mrpack，多版本记录
model Modpack {
  id         String @id @default(cuid())
  serverId   String @map("server_id")
  uploaderId String @map("uploader_id")

  name        String
  version     String?
  loader      String?
  gameVersion String? @map("game_version")
  summary     String? @db.Text

  fileKey  String @map("file_key")
  fileSize Int    @map("file_size")
  sha1     String
  sha512   String

  mrIndex      Json    @map("mr_index")
  modsCount    Int     @map("mods_count")
  hasOverrides Boolean @default(false) @map("has_overrides")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  server   Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  uploader User   @relation(fields: [uploaderId], references: [id], onDelete: Cascade)

  @@index([serverId])
  @@map("modpacks")
}

/// 站内通知 —— 评论回复、服务器上线、审核结果等
model Notification {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now()) @map("created_at")
  readAt    DateTime? @map("read_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type    String
  title   String
  message String
  link    String?

  serverId  String? @map("server_id")
  commentId String? @map("comment_id")

  @@index([userId, readAt])
  @@map("notifications")
}

/// 内容审查日志 —— 记录每次 AI 审查的结果，供管理员查看和复核
model ModerationLog {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now()) @map("created_at")

  /// 被审查的内容类型：server | modpack | username | comment
  contentType    String  @map("content_type")
  /// 关联的内容 ID（如服务器 ID、评论 ID 等，username/bio 无独立 ID 时为 null）
  contentId      String? @map("content_id")
  /// 被审查的原始文本（截断存储）
  contentSnippet String  @map("content_snippet") @db.VarChar(500)

  /// AI 审查结果
  passed     Boolean
  aiCategory String? @map("ai_category")
  aiReason   String? @map("ai_reason")

  /// 提交者信息
  userId String? @map("user_id")
  userIp String? @map("user_ip")

  /// 管理员复核
  reviewed  Boolean @default(false)
  adminNote String? @map("admin_note")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([contentType, passed])
  @@index([createdAt])
  @@index([reviewed, passed])
  @@map("moderation_logs")
}

/// 更新日志 —— 管理员发布的平台更新记录
model Changelog {
  id          String    @id @default(cuid())
  title       String
  content     String    @db.Text
  type        String    @default("feature") // feature | fix | improvement | other
  published   Boolean   @default(false)
  publishedAt DateTime? @map("published_at")
  authorId    String    @map("author_id")
  author      User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([published, publishedAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("changelogs")
}

/// 数字 ID 预留表 —— 确保 PSID/UID 删除后不被复用
model ReservedNumericId {
  id        String   @id @default(cuid())
  type      String // "psid" | "uid"
  numericId Int      @map("numeric_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([type, numericId], name: "unique_type_numeric_id")
  @@index([type])
  @@map("reserved_numeric_ids")
}

/// 玩家入服申请 —— 私域服务器的审核机制
model ServerApplication {
  id         String   @id @default(cuid())
  serverId   String   @map("server_id")
  userId     String   @map("user_id")
  status     String   @default("pending") @map("status") // pending | approved | rejected | cancelled
  formData   Json?    @map("form_data")
  reviewNote String?  @map("review_note")
  reviewedBy String?  @map("reviewed_by")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  server   Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  user     User   @relation("ApplicationUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewer User?  @relation("ApplicationReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@unique([serverId, userId], name: "unique_server_application")
  @@index([serverId, status])
  @@index([userId])
  @@map("server_applications")
}

/// 服务器邀请码 —— 用于邀请制入服
model ServerInvite {
  id        String    @id @default(cuid())
  serverId  String    @map("server_id")
  code      String    @unique
  createdBy String    @map("created_by")
  maxUses   Int?      @map("max_uses")
  usedCount Int       @default(0) @map("used_count")
  expiresAt DateTime? @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  server  Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
  creator User   @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([serverId])
  @@map("server_invites")
}

/// 服务器成员 —— 已通过审核或邀请的玩家
model ServerMember {
  id         String   @id @default(cuid())
  serverId   String   @map("server_id")
  userId     String   @map("user_id")
  joinedVia  String   @map("joined_via") // apply | invite
  mcUsername String?  @map("mc_username")
  createdAt  DateTime @default(now()) @map("created_at")

  server Server          @relation(fields: [serverId], references: [id], onDelete: Cascade)
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  syncs  WhitelistSync[]

  @@unique([serverId, userId], name: "unique_server_member")
  @@index([serverId])
  @@index([userId])
  @@map("server_members")
}

/// 白名单同步记录 —— 追踪每次白名单变更的推送和确认状态
model WhitelistSync {
  id            String    @id @default(cuid())
  serverId      String    @map("server_id")
  memberId      String    @map("member_id")
  action        String // add | remove
  status        String    @default("pending") // pending | pushed | acked | failed
  retryCount    Int       @default(0) @map("retry_count")
  lastAttemptAt DateTime? @map("last_attempt_at")
  ackedAt       DateTime? @map("acked_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  server Server       @relation(fields: [serverId], references: [id], onDelete: Cascade)
  member ServerMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([serverId, status])
  @@index([memberId])
  @@map("whitelist_syncs")
}

